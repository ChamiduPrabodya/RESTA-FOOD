PORT=5000
HOST=0.0.0.0
CLIENT_ORIGIN=http://localhost:5173

# Optional: allow multiple frontend origins (comma-separated). Useful for LAN testing (phone scanning QR).
# Example: CLIENT_ORIGINS=http://localhost:5173,http://192.168.1.20:5173
CLIENT_ORIGINS=

# Optional: public frontend base URL used to generate table QR links.
# Can include a path (e.g. Vite base): http://192.168.1.20:5173/RESTA-FOOD/
PUBLIC_FRONTEND_ORIGIN=
JWT_SECRET=dev_secret_change_me

# Admin account (required)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Google Identity
# Comma-separated list is allowed (e.g. web + android client IDs)
GOOGLE_CLIENT_ID=

# MongoDB (required)
# You can use MongoDB Atlas or a local MongoDB instance.
MONGODB_URI=

# Optional fallback URI if your primary URI is mongodb+srv:// and SRV lookups are blocked on your network.
# Example (local MongoDB): mongodb://127.0.0.1:27017/hotel_management_system
MONGODB_URI_FALLBACK=
MONGODB_DB_NAME=

# Optional: override DNS resolvers used for mongodb+srv SRV/TXT lookups.
# Use this if you get `querySrv ECONNREFUSED` on startup.
MONGODB_DNS_SERVERS=

# PayHere (Card payments via Checkout API)
# Note: PayHere cannot call notify_url on localhost; use a public URL (ngrok, your domain, etc.)
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_CURRENCY=LKR
PAYHERE_SANDBOX=true
PAYHERE_RETURN_URL=http://localhost:5173/payment/success
PAYHERE_CANCEL_URL=http://localhost:5173/payment/cancel
PAYHERE_NOTIFY_URL=
